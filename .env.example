# Environment Configuration for WayAI Platform

# Network Configuration
VITE_NETWORK_ID=11155111
VITE_NETWORK_NAME=sepolia
VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
VITE_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io

# Alternative RPC providers (choose the best one)
# Infura
VITE_INFURA_PROJECT_ID=your_infura_project_id_here
# Alchemy
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here
# QuickNode
VITE_QUICKNODE_URL=your_quicknode_url_here

# Contract Addresses (Deploy these contracts first)
VITE_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TOKEN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_STAKING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Faucet Configuration
VITE_FAUCET_URL=https://sepoliafaucet.com/api/faucet
VITE_FAUCET_API_KEY=your_faucet_api_key_here
VITE_FAUCET_INTERVAL_MINUTES=1440

# AI Agent Configuration
VITE_AI_API_URL=https://api.openai.com/v1
VITE_AI_API_KEY=your_openai_api_key_here
VITE_AI_MODEL=gpt-4
VITE_AI_MAX_TOKENS=2000

# IPFS Configuration (for NFT metadata)
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_KEY=your_pinata_secret_key_here

# Application Configuration
VITE_APP_NAME=WayAI
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-powered NFT platform with DeFi capabilities
VITE_APP_URL=https://wayai.app
VITE_APP_SUPPORT_EMAIL=support@wayai.app

# Security Configuration
VITE_ENCRYPTION_KEY=your_encryption_key_here
VITE_JWT_SECRET=your_jwt_secret_here
VITE_SESSION_TIMEOUT=3600000

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here

# Feature Flags
VITE_ENABLE_STAKING=true
VITE_ENABLE_LENDING=false
VITE_ENABLE_GOVERNANCE=false
VITE_ENABLE_BRIDGE=false
VITE_ENABLE_AIRDROP=true

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=900000

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG=true
VITE_LOG_LEVEL=debug